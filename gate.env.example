# Aether-gate — secrets for docker compose.
#
#   cp gate.env.example gate.env
#   chmod 600 gate.env
#
# Keep the login HERE rather than in docker-compose.yml or a systemd ExecStart:
# a command line is readable by every user on the box (ps, systemctl show), a
# 0600 file is not. gate.env is gitignored and excluded from the build context.
#
# The RS-BA1 "Network User" you set on the radio
# (Menu > Set > Network > Network User1). Both radios can share one login.
#
# NOTE the variable follows argparse's destination, not the flag spelling:
# --pass is stored as `pw`, so it is AETHER_GATE_PW -- not AETHER_GATE_PASS.
AETHER_GATE_USER=changeme
AETHER_GATE_PW=changeme
